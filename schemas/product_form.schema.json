{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hawkeye.local/schemas/product_form.schema.json",
  "title": "Hawkeye Normalized Product Listing Form",
  "type": "object",
  "additionalProperties": false,
  "required": ["product", "supplier", "provenance"],
  "properties": {
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["listing_type", "canonical_name"],
      "properties": {
        "listing_type": {
          "type": "string",
          "enum": ["API", "FDF"]
        },
        "canonical_name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "examples": ["Acetaminophen", "Ibuprofen Tablets"]
        },
        "synonyms": {
          "type": "array",
          "items": { "type": "string", "maxLength": 120 },
          "uniqueItems": true,
          "default": []
        },
        "description": {
          "type": "string",
          "maxLength": 5000,
          "default": ""
        },
        "identifiers": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cas": {
              "type": "string",
              "pattern": "^\\d{2,7}-\\d{2}-\\d$",
              "examples": ["103-90-2"]
            },
            "inn": { "type": "string", "maxLength": 200 },
            "unii": { "type": "string", "pattern": "^[A-Z0-9]{10}$" },
            "gsrs_id": { "type": "string", "maxLength": 64 },
            "product_ndc": { "type": "string", "pattern": "^\\d{4,5}-\\d{3,4}-\\d{1,2}$" },
            "package_ndc": { "type": "string", "pattern": "^\\d{4,5}-\\d{3,4}-\\d{1,2}$" }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "listing_type": { "const": "API" } },
            "required": ["listing_type"]
          },
          "then": {
            "anyOf": [
              { "properties": { "identifiers": { "required": ["cas"] } } },
              { "properties": { "identifiers": { "required": ["inn"] } } }
            ]
          }
        }
      ]
    },
    "fdf": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dosage_form": {
          "type": "string",
          "enum": ["TABLET", "CAPSULE", "SUSPENSION", "INJECTION", "CREAM", "PATCH", "OTHER"]
        },
        "strength": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 },
            "unit": { "type": "string", "enum": ["mg", "mcg", "%", "mg/mL", "IU", "g"] }
          }
        },
        "route": {
          "type": "string",
          "enum": ["ORAL", "IV", "IM", "TOPICAL", "INHALATION", "OPHTHALMIC", "OTHER"]
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "spec_reference": {
          "type": "string",
          "enum": ["USP", "Ph.Eur.", "JP", "BP", "ChP", "In-house", "Other"]
        },
        "specs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "api": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "assay_percent": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "value": { "type": "number", "minimum": 0, "maximum": 100 },
                    "comparator": { "type": "string", "enum": [">=", "<=", "=", "range"] }
                  }
                },
                "impurities": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["name", "limit", "unit"],
                    "properties": {
                      "name": { "type": "string", "maxLength": 200 },
                      "limit": { "type": "number" },
                      "unit": { "type": "string", "maxLength": 20 },
                      "comparator": { "type": "string", "enum": [">=", "<=", "="] }
                    }
                  },
                  "default": []
                },
                "polymorph": { "type": "string", "maxLength": 120 },
                "particle_size": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "d10": { "type": "number" },
                    "d50": { "type": "number" },
                    "d90": { "type": "number" },
                    "unit": { "type": "string", "maxLength": 20 },
                    "method": { "type": "string", "maxLength": 120 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "stability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "storage_conditions": {
          "type": "string",
          "enum": ["2-8C", "15-25C", "Controlled room temperature", "Protect from light", "Frozen", "Other"]
        },
        "shelf_life_months": { "type": "integer", "minimum": 1, "maximum": 120 },
        "retest_period_months": { "type": "integer", "minimum": 1, "maximum": 120 }
      },
      "oneOf": [
        { "required": ["shelf_life_months"], "not": { "required": ["retest_period_months"] } },
        { "required": ["retest_period_months"], "not": { "required": ["shelf_life_months"] } },
        { "not": { "anyOf": [ { "required": ["shelf_life_months"] }, { "required": ["retest_period_months"] } ] } }
      ]
    },
    "packaging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pack_configurations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pack_size", "unit", "material"],
            "properties": {
              "pack_size": { "type": "number", "exclusiveMinimum": 0 },
              "unit": { "type": "string", "maxLength": 40 },
              "material": { "type": "string", "maxLength": 120 },
              "inner_outer": { "type": "string", "maxLength": 120 }
            }
          },
          "default": []
        }
      }
    },
    "supply": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "moq": {
          "type": "object",
          "additionalProperties": false,
          "required": ["unit"],
          "properties": {
            "value": { "type": ["number", "null"], "exclusiveMinimum": 0 },
            "unit": { "type": "string", "enum": ["kg", "g", "units", "vials", "L", "packs"] },
            "is_negotiable": { "type": "boolean", "default": false }
          }
        },
        "lead_time_days": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": { "type": "integer", "minimum": 0, "maximum": 3650 },
            "max": { "type": "integer", "minimum": 0, "maximum": 3650 }
          }
        },
        "price": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
            "amount": { "type": ["number", "null"], "minimum": 0 },
            "basis": { "type": "string", "maxLength": 40 },
            "is_on_request": { "type": "boolean", "default": false }
          }
        }
      }
    },
    "trade": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "country_of_origin": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "hs_code": { "type": "string", "pattern": "^\\d{6}(\\d{2,4})?$" }
      }
    },
    "supplier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "role"],
      "properties": {
        "name": { "type": "string", "minLength": 2 },
        "role": {
          "type": "array",
          "items": { "type": "string", "enum": ["manufacturer", "distributor", "trader", "cdmo"] },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "manufacturing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sites": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "country", "roles"],
            "properties": {
              "name": { "type": "string", "minLength": 2 },
              "address": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "address1": { "type": "string", "maxLength": 240 },
                  "address2": { "type": "string", "maxLength": 240 },
                  "city": { "type": "string", "maxLength": 120 },
                  "state": { "type": "string", "maxLength": 120 },
                  "postal_code": { "type": "string", "maxLength": 40 },
                  "country": { "type": "string", "pattern": "^[A-Z]{2}$" }
                }
              },
              "country": { "type": "string", "pattern": "^[A-Z]{2}$" },
              "roles": {
                "type": "array",
                "items": { "type": "string", "enum": ["api_manufacturing", "fdf_manufacturing", "packaging", "testing", "release"] },
                "minItems": 1,
                "uniqueItems": true
              }
            }
          },
          "default": []
        }
      }
    },
    "compliance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "claims": {
          "type": "array",
          "items": { "type": "string", "enum": ["GMP", "cGMP", "USDMF", "JDMF", "KDMF", "CEP", "COA", "SDS", "ISO9001", "GDP", "AuditReport"] },
          "uniqueItems": true,
          "default": []
        },
        "dmf_records": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["authority", "type", "number", "status"],
            "properties": {
              "authority": { "type": "string", "maxLength": 80 },
              "type": { "type": "string", "maxLength": 40 },
              "number": { "type": "string", "maxLength": 80 },
              "status": { "type": "string", "maxLength": 40 }
            }
          },
          "default": []
        },
        "cep_records": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["cep_number", "status"],
            "properties": {
              "cep_number": { "type": "string", "maxLength": 80 },
              "status": { "type": "string", "maxLength": 40 },
              "issue_date": { "type": "string", "format": "date" },
              "end_date": { "type": "string", "format": "date" }
            }
          },
          "default": []
        }
      },
      "allOf": [
        {
          "if": { "properties": { "claims": { "contains": { "const": "CEP" } } } },
          "then": { "required": ["cep_records"], "properties": { "cep_records": { "minItems": 1 } } }
        },
        {
          "if": { "properties": { "claims": { "contains": { "enum": ["USDMF", "JDMF", "KDMF"] } } } },
          "then": { "required": ["dmf_records"], "properties": { "dmf_records": { "minItems": 1 } } }
        }
      ]
    },
    "documents": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "evidence_docs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["doc_type", "sha256"],
            "properties": {
              "doc_id": { "type": "string", "maxLength": 128 },
              "doc_type": { "type": "string", "enum": ["COA", "SDS", "GMP_CERT", "CEP_REFERENCE", "DMF_REFERENCE", "AUDIT_REPORT", "METHOD", "STABILITY_SUMMARY", "OTHER"] },
              "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
              "source_url": { "type": "string", "format": "uri" },
              "issued": { "type": "string", "format": "date" },
              "expires": { "type": "string", "format": "date" },
              "extracted_fields": { "type": "object" },
              "batch_scope": {
                "type": "object",
                "properties": {
                  "batch": { "type": "string", "maxLength": 80 },
                  "lot": { "type": "string", "maxLength": 80 },
                  "release_date": { "type": "string", "format": "date" }
                }
              }
            }
          },
          "default": []
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sources", "visibility"],
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_name", "fetched_at", "confidence"],
            "properties": {
              "source_name": { "type": "string", "maxLength": 120 },
              "url": { "type": "string", "format": "uri" },
              "fetched_at": { "type": "string", "format": "date-time" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          },
          "minItems": 1
        },
        "visibility": { "type": "string", "enum": ["public", "registered", "private"] }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "product": { "properties": { "listing_type": { "const": "FDF" } } } }
      },
      "then": {
        "required": ["fdf"],
        "properties": {
          "fdf": {
            "required": ["dosage_form", "strength"],
            "properties": { "strength": { "required": ["value", "unit"] } }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "compliance": { "properties": { "claims": { "contains": { "enum": ["GMP", "cGMP"] } } } } }
      },
      "then": {
        "required": ["manufacturing", "documents"],
        "properties": {
          "manufacturing": { "properties": { "sites": { "minItems": 1 } } },
          "documents": {
            "properties": {
              "evidence_docs": {
                "contains": {
                  "type": "object",
                  "properties": { "doc_type": { "const": "GMP_CERT" } },
                  "required": ["doc_type"]
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "documents": {
            "properties": {
              "evidence_docs": {
                "contains": {
                  "type": "object",
                  "properties": { "doc_type": { "const": "COA" } },
                  "required": ["doc_type"]
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "documents": {
            "properties": {
              "evidence_docs": {
                "items": {
                  "if": { "properties": { "doc_type": { "const": "COA" } }, "required": ["doc_type"] },
                  "then": {
                    "properties": {
                      "batch_scope": {
                        "required": ["release_date"],
                        "properties": {
                          "batch": { "type": "string" },
                          "lot": { "type": "string" },
                          "release_date": { "type": "string", "format": "date" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
